# ─── Veterinaria Scarlet — Variables de entorno ───────────────────────────────
#
# Copia este archivo a .env y completa los valores:
#   cp .env.example .env
#
# NUNCA commitees el archivo .env real al repositorio.
# ─────────────────────────────────────────────────────────────────────────────

# ── Django ────────────────────────────────────────────────────────────────────

# Clave secreta de Django. Generar con:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=cambia-esto-por-una-clave-secreta-real

# True en desarrollo, False en producción (obligatorio)
DEBUG=True

# Hosts permitidos, separados por coma
# Ejemplo producción: api.mivetapp.cl,.onrender.com
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Base de datos ─────────────────────────────────────────────────────────────

# URL de conexión a PostgreSQL
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_db
# Supabase: se obtiene en Project Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:tu_password@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# ── CORS / CSRF ───────────────────────────────────────────────────────────────

# Orígenes del frontend permitidos para CORS, separados por coma
# Ejemplo: https://mivetapp.vercel.app,http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Orígenes de confianza para CSRF (necesario si usas el Django Admin desde prod)
# Ejemplo: https://mivetapp.cl,https://www.mivetapp.cl
CSRF_TRUSTED_ORIGINS=http://localhost:3000

# ── Caché (opcional) ──────────────────────────────────────────────────────────

# URL de Redis para caché. Si no se define, se usa LocMemCache (un solo proceso).
# Ejemplo: redis://localhost:6379/1
# CACHE_URL=redis://localhost:6379/1

# ── Registro de clínicas ──────────────────────────────────────────────────────

# Contraseña secreta requerida para crear nuevas clínicas.
# Sin esta clave, el endpoint /api/v1/registro/ rechaza todas las solicitudes.
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(32))"
REGISTRO_SECRET_KEY=cambia-esto-por-una-clave-secreta-de-registro

# ── Email (opcional) ──────────────────────────────────────────────────────────

# Configuración SMTP para el correo de bienvenida al registrar una clínica.
# Si no se configura, el correo falla silenciosamente (el registro igual funciona).
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=tu_correo@gmail.com
# EMAIL_HOST_PASSWORD=tu_app_password
# DEFAULT_FROM_EMAIL=noreply@veterinariascarlet.cl
